# --- Local dev defaults ---
DATABASE_URL=postgresql+asyncpg://holdings:holdings@localhost:5432/holdings
REDIS_URL=redis://localhost:6379/0

# SEC EDGAR requires a descriptive User-Agent (include your name + email)
# See https://www.sec.gov/developer
EDGAR_USER_AGENT="YourName your@email.com"

# --- LLM enrichment (get free keys from the respective dashboards) ---
# https://console.groq.com
GROQ_API_KEY=
# https://app.tavily.com
TAVILY_API_KEY=

# --- Production only ---
# Comma-separated list of origins allowed to call the API from a browser.
# Local: http://localhost:3000,http://127.0.0.1:3000
# Prod:  https://your-frontend.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Shared secret for write endpoints (POST /investors, /sync, /research, /alerts).
# If empty, writes are unauthenticated (local dev only — DO NOT leave empty in prod).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
